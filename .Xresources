XTerm.VT100*background:rgb:0c/0c/0c
XTerm.VT100*foreground:rgb:f7/f7/f7

!!!!!below work
XTerm.vt100.geometry:100x30+100+100
!60 row can show the menu
!XTerm.VT100.geometry:400x400+0+0
!XTerm.vt100.Geometry:400x400+0+0
!!!!!above work
XTerm.VT100.SelectToClipboard:true
XTerm.VT100.MetaSendsEscape:true
XTerm.VT100.FaceName:Adwaita Mono
XTerm.VT100.faceSize:14
XTerm.VT100.faceSize2:16
XTerm.VT100.faceSize3:18
XTerm.VT100.faceSize3:19
XTerm.VT100.RenderFont:true
XTerm.VT100.CursorColor:rgb:80/80/80
!xterm.VT100.geometry:400x400+0+0 this don work
!xterm.vt100.geometry:400x400+0+0 this don work either

! Allow XTerm font size to be changed with Ctrl+<plus> and <minus>
XTerm.vt100.translations: #override \n\
  Ctrl <Key> minus: smaller-vt-font() \n\
  Ctrl <Key> plus: larger-vt-font()
!WORKED SUCCESSFULLY
